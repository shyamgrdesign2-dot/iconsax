node_modules
.DS_Store
.env
.env.local

# crawler state (intermediate)
crawl-state/

# Pre-merge per-source SVGs. Kept locally so `npm run merge` can be re-run
# after a crawl, but not shipped — the merged svg/ tree is what consumers use.
svg-source/

# src/ is regenerated from svg/ in ~1s by `npm run generate`. Keeping it out of
# git cuts ~18,000 files. dist/ is committed so `npm install` works without a
# build step.
src/

# Don't ignore svg/ and dist/ — those are the package contents.

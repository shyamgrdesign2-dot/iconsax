{
  "name": "tp_icon",
  "version": "0.3.0",
  "description": "Unified icon library (Iconsax free + Iconsax Pro + TP Medical) as React components and raw SVGs. 25K+ components across 6 styles.",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bold":    { "types": "./dist/bold/index.d.ts",    "import": "./dist/bold/index.js" },
    "./broken":  { "types": "./dist/broken/index.d.ts",  "import": "./dist/broken/index.js" },
    "./bulk":    { "types": "./dist/bulk/index.d.ts",    "import": "./dist/bulk/index.js" },
    "./linear":  { "types": "./dist/linear/index.d.ts",  "import": "./dist/linear/index.js" },
    "./outline": { "types": "./dist/outline/index.d.ts", "import": "./dist/outline/index.js" },
    "./twotone": { "types": "./dist/twotone/index.d.ts", "import": "./dist/twotone/index.js" },
    "./svg/*": "./svg/*",
    "./icons.json": "./icons.json"
  },
  "files": [
    "dist",
    "svg",
    "icons.json",
    "README.md"
  ],
  "scripts": {
    "crawl:pro": "node scripts/discover.mjs && SOURCE=pro node scripts/fetch.mjs",
    "crawl:free": "node scripts/discover-free.mjs && SOURCE=free node scripts/fetch.mjs",
    "import:tp": "node scripts/import-tp.mjs",
    "merge": "node scripts/merge.mjs",
    "generate": "node scripts/generate.mjs",
    "build": "node scripts/build.mjs",
    "rebuild:all": "npm run merge && npm run generate && npm run build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "icons",
    "iconsax",
    "tatvapractice",
    "tp",
    "react",
    "svg"
  ],
  "license": "UNLICENSED",
  "private": false
}
